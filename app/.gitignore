# Generated by Cargo
# will have compiled files and executables
/target/
/gen/schemas

# App icons are generated from icons/icon.svg by scripts/lib/generate-app-icons.sh
# (bun run gen:icons), wired into Tauri's before{Dev,Build}Command. The SVG is the
# only tracked source; the rasterized set (icon.icns/.ico/.png, Store/Square PNGs,
# and the android/ios folders) is build output.
/icons/*
!/icons/icon.svg
