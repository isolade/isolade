{
  "name": "isolade",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "./scripts/dev.sh",
    "app": "./scripts/app.sh",
    "build": "./scripts/build.sh",
    "gen:icons": "./scripts/lib/generate-app-icons.sh",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:browser": "bun run --cwd packages/web test:browser",
    "test:browser:stress": "bun run --cwd packages/web test:browser:stress",
    "bootstrap:microsandbox": "./scripts/bootstrap-microsandbox.sh",
    "seed-usage": "bun run scripts/seed-usage.ts",
    "refresh-catalog": "bun run scripts/refresh-catalog.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@tauri-apps/cli": "2.11.4",
    "oxlint": "1.74.0",
    "typescript": "7.0.2"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "patchedDependencies": {
    "microsandbox@0.6.6": "patches/microsandbox@0.6.6.patch"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "hono": "^4.12.30",
    "lucide-react": "^1.24.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4",
    "zod": "^4.4.3"
  }
}
